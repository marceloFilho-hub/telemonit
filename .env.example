# telemonit — variáveis de ambiente do projeto cliente

# Identificador do projeto que está usando a lib
MONITOR_PROJETO=meu_projeto

# Credenciais Telegram (resolvidas em runtime via Service Account)
MONITOR_TG_TOKEN=drive:<file_id_do_token_donna>
MONITOR_TG_CHAT_ID=drive:<file_id_do_chat_id>

# Pasta no Drive onde os eventos JSONL serão gravados
MONITOR_DRIVE_LOG_FOLDER=<id_da_pasta_de_logs>

# Nível mínimo para envio Telegram: info | alerta | erro
MONITOR_NIVEL=alerta

# Service Account com acesso de escrita à pasta de logs
GOOGLE_APPLICATION_CREDENTIALS=credentials/gdrive_service_account.json
